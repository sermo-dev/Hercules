namespace hercules {
    [Throws=HerculesError]
    BlockInfo parse_block_header(string hex_header);
    string hercules_version();
};

dictionary BlockInfo {
    string block_hash;
    string prev_block_hash;
    string merkle_root;
    u32 version;
    u32 timestamp;
    string timestamp_human;
    u32 bits;
    u32 nonce;
};

dictionary PeerInfo {
    string addr;
    string user_agent;
    u32 height;
};

dictionary SyncStatus {
    u32 synced_headers;
    u32 peer_height;
    sequence<PeerInfo> peers;
    string active_peer_addr;
    boolean is_syncing;
    u32 validated_blocks;
    string? error;
};

dictionary SnapshotInfo {
    u32 height;
    u64 utxo_count;
    string utxo_hash;
};

dictionary BlockNotification {
    u32 height;
    string block_hash;
    string prev_block_hash;
    u32 timestamp;
    string timestamp_human;
    boolean validated;
    boolean header_validated;
    string? validation_error;
};

dictionary TorStatus {
    boolean is_bootstrapped;
    u8 bootstrap_progress;
    string? onion_address;
};

callback interface SyncCallback {
    void on_progress(SyncStatus status);
};

callback interface SnapshotCallback {
    void on_progress(u64 loaded, u64 total);
};

interface HerculesNode {
    [Throws=HerculesError]
    constructor(string db_path, string? tor_data_dir);

    [Throws=HerculesError]
    SyncStatus get_status();

    [Throws=HerculesError]
    void start_header_sync(SyncCallback callback);

    [Throws=HerculesError]
    boolean needs_snapshot();

    [Throws=HerculesError]
    SnapshotInfo load_snapshot(string snapshot_path, SnapshotCallback callback);

    [Throws=HerculesError]
    BlockNotification validate_latest_block(u32 timeout_secs);

    void stop_sync();
    void set_validation_paused(boolean paused);
    boolean is_validation_paused();
    TorStatus? get_tor_status();
};

[Error]
interface HerculesError {
    SyncFailed(string msg);
    StorageError(string msg);
    NetworkError(string msg);
    TorError(string msg);
};
